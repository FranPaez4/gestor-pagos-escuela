<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Desactiva el header obligatorio -->
    <suppress checks="SpringHeader" files=".*"/>

    <!-- Desactiva Javadoc de paquetes (package-info.java) -->
    <suppress checks="JavadocPackage" files=".*"/>

    <!-- Desactiva orden de imports si quieres que Spotless lo gestione -->
    <suppress checks="SpringImportOrder" files=".*"/>

    <!-- Espacios vs tabs serán corregidos por Spotless -->
    <suppress checks="SpringLeadingWhitespace" files=".*"/>
</suppressions>